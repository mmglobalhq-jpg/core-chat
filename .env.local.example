# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.

# --- Backend gateway target (server-side proxy: app/api/intent/route.ts) ---
# Where the proxy forwards chat requests. Use the public Cloudflare edge
# (https://api.mmglobal.us) so the CF Access + Bearer headers below are honored,
# or an internal URL (e.g. http://backend:8000) when co-located with the backend.
CORE_API_URL=https://api.mmglobal.us

# --- Supabase (PUBLIC — inlined into the browser bundle, safe to expose) ---
# Dashboard -> Project Settings -> API. The anon/publishable key is public.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# --- Supabase service-role key (SERVER-ONLY — never prefix NEXT_PUBLIC) ---
# Used by /api/admin/* and the auth gates. Dashboard -> Project Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=your-chat-project-service-role-key

# --- Cloudflare Access service token (SERVER-ONLY — never prefix NEXT_PUBLIC) ---
# Zero Trust -> Access -> Service Auth -> Service Tokens. Required only when
# CORE_API_URL points at an Access-protected host (api.mmglobal.us).
CF_ACCESS_CLIENT_ID=your-cf-access-client-id
CF_ACCESS_CLIENT_SECRET=your-cf-access-client-secret

# --- Fund Manager: the JP Fund poller's Supabase project (SERVER-ONLY) ---
# The poller runs in a SEPARATE Supabase project from this chat app. The
# /api/funds/* routes call that project's read-only position-change RPCs with the
# poller project's service-role key. NEVER prefix these with NEXT_PUBLIC — they
# must not reach the browser bundle.
FUNDS_SUPABASE_URL=https://your-poller-project-ref.supabase.co
FUNDS_SUPABASE_SERVICE_ROLE_KEY=your-poller-project-service-role-key
# Optional: max rows a single CSV export may contain (default 100000).
FUNDS_EXPORT_MAX_ROWS=100000

# --- REIT Research: the ARR research engine's Supabase project (SERVER-ONLY) ---
# The /api/reits/* routes call the engine's normalized reader-contract RPCs
# (reit_research_*_v1, migration 0005). EXECUTE is granted only to the service role
# (which bypasses the underlying forced RLS). NEVER prefix these with NEXT_PUBLIC —
# they must not reach the browser bundle. The report body (Markdown) is read from
# the database, so no Storage bucket variable is required. This may be the same
# Supabase project as this chat app, but the client stays dedicated + isolated.
REITS_SUPABASE_URL=https://your-reit-research-project-ref.supabase.co
REITS_SUPABASE_SERVICE_ROLE_KEY=your-reit-research-project-service-role-key

# --- Data Intelligence gateway (OPTIONAL, feature-flagged, SERVER-ONLY) ---
# The query_data tool integrates the data-intelligence-gateway. Both flags
# default false; when false, no tool is exposed and chat behavior is unchanged.
# NEVER prefix these with NEXT_PUBLIC — the browser must not learn the gateway
# URL, the signing secret, or that the tool exists.
DATA_INTELLIGENCE_ENABLED=false
DATA_INTELLIGENCE_FUNDS_ENABLED=false
# Server-side base URL of the gateway (e.g. http://gateway:8080 on the internal
# network). The browser never calls this directly.
DATA_INTELLIGENCE_GATEWAY_URL=http://127.0.0.1:8088
# HS256 signing secret for the short-lived service token. MUST equal the
# gateway's DIG_SERVICE_TOKEN_SECRET. Use a strong, unique value.
DATA_INTELLIGENCE_SIGNING_SECRET=set-a-strong-shared-secret-here
